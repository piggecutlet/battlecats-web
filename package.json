{
  "name": "battlecats-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "lefthook install",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "knip": "knip",
    "knip:fix": "knip --fix-type exports --fix-type types",
    "lint": "eslint \"**/*.{cjs,cts,js,jsx,mjs,mts,ts,tsx}\"",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --write '**/*.{cjs,css,cts,html,js,json,json5,jsonc,jsx,md,mdc,mjs,mts,ts,tsx,yaml,yml}'",
    "fix": "pnpm knip:fix && pnpm lint:fix && pnpm format"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-perfectionist": "^5.9.0",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "^5"
  }
}
